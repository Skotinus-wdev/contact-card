# Google Wallet API Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001

# Google Wallet Configuration
# Get your Issuer ID from Google Pay & Wallet Console: https://pay.google.com/business/console
GOOGLE_WALLET_ISSUER_ID=your-issuer-id-here

# Service Account Key (JSON string)
# 1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create a service account with "Wallet Object Issuer" role
# 3. Create a key (JSON) and download it
# 4. Copy the entire JSON content and paste it as a single line here
# Or use: export GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=$(cat service-account-key.json | jq -c .)
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}